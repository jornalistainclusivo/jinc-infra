# ==============================================================================
# JINC REBUILD - AMBIENTE DE ORQUESTRAÇÃO (EXEMPLO)
# ==============================================================================

# --- AMBIENTE GERAL ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- CMS (STRAPI 5) ---
# Caminho absoluto fixado para evitar erro EACCES no Docker
DATABASE_FILENAME=/opt/app/.tmp/data.db
STRAPI_PORT=1337

# Chaves de Segurança (Gerar strings aleatórias de 32+ caracteres)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=troque_por_um_valor_aleatorio
ADMIN_JWT_SECRET=troque_por_um_valor_aleatorio
TRANSFER_TOKEN_SALT=troque_por_um_valor_aleatorio
JWT_SECRET=troque_por_um_valor_aleatorio

# --- FRONTEND (NEXT.JS) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337
INTERNAL_STRAPI_URL=http://cms:1337

# --- INTELIGÊNCIA ARTIFICIAL ---
GEMINI_API_KEY=sua_chave_gemini_aqui

# --- MIGRACAO (SCRIPTS) ---
# Usado pelo script Python para injetar dados no Strapi
MIGRATION_TOKEN=seu_full_access_token_gerado_no_painel
WORDPRESS_DB_HOST=localhost
WORDPRESS_DB_USER=root
WORDPRESS_DB_PASSWORD=sua_senha_mariadb
WORDPRESS_DB_NAME=nome_do_banco_wordpress
